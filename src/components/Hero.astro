---
const samarth = 'https://muugadmission.samarth.edu.in/';
---
<section id="top" class="relative overflow-hidden bg-hero-glow">
  <div class="absolute inset-x-0 top-0 -z-10 h-64 bg-gradient-to-b from-mist/70 to-transparent"></div>
  <div class="section-shell grid gap-10 py-14 sm:py-20 lg:grid-cols-[1.08fr_0.92fr] lg:items-center lg:py-24">
    <div>
      <p class="mb-5 inline-flex items-center gap-2 rounded-full border border-blue-200 bg-white px-4 py-2 text-xs font-extrabold uppercase tracking-[0.18em] text-brand shadow-sm">
        <span class="h-2.5 w-2.5 rounded-full bg-emerald-500"></span> Admissions Open
      </p>
      <p class="mb-4 text-sm font-bold uppercase tracking-[0.18em] text-slate-500">B.Com (Retail Operations Management) (AEDP)</p>
      <h1 class="font-display text-4xl font-bold leading-tight tracking-tight text-navy sm:text-5xl lg:text-6xl">Build Your Career in Retail, E-Commerce & Modern Business</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">A career-focused B.Com degree by University of Mumbai with practical retail learning, industry exposure and apprenticeship-oriented training.</p>
      <div class="mt-7 flex flex-wrap gap-3" aria-label="Programme highlights">
        {['University of Mumbai', 'AEDP Programme', 'Intake: 30 Seats', 'Admissions: 6 May to 21 May 2026'].map((chip) => (
          <span class="rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-bold text-navy shadow-sm">{chip}</span>
        ))}
      </div>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <a class="btn-primary" href={samarth} target="_blank" rel="noopener noreferrer">Apply Now</a>
        <a class="btn-secondary" href="#videos">Watch Admission Guide</a>
        <a class="btn-secondary" href="#contact">Talk to Counsellor</a>
      </div>
      <div class="mt-8 rounded-3xl border border-amber-200 bg-amber-50 p-5 text-sm font-semibold leading-6 text-amber-950 shadow-sm">
        <strong>Important:</strong> Online registration on the Mumbai University Samarth Portal is compulsory before institute-level offline admission.
      </div>
    </div>
    <div class="relative">
      <div class="rounded-[2rem] border border-white bg-white/80 p-5 shadow-soft backdrop-blur">
        <div class="rounded-[1.5rem] bg-gradient-to-br from-navy via-blue-900 to-brand p-7 text-white">
          <p class="text-sm font-bold uppercase tracking-[0.2em] text-blue-200">Apprenticeship Embedded Degree Programme</p>
          <h2 class="mt-5 font-display text-3xl font-bold">A practical commerce pathway for students after 12th</h2>
          <div class="mt-8 grid gap-4 sm:grid-cols-2">
            <div class="rounded-2xl bg-white/12 p-4 backdrop-blur"><strong class="block text-2xl">30</strong><span class="text-sm text-blue-100">Seats intake</span></div>
            <div class="rounded-2xl bg-white/12 p-4 backdrop-blur"><strong class="block text-2xl">6–21 May</strong><span class="text-sm text-blue-100">Admission window</span></div>
            <div class="rounded-2xl bg-white/12 p-4 backdrop-blur"><strong class="block text-2xl">Eligibility</strong><span class="text-sm text-blue-100">12th Standard</span></div>
            <div class="rounded-2xl bg-white/12 p-4 backdrop-blur"><strong class="block text-2xl">B.Com</strong><span class="text-sm text-blue-100">University degree</span></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
