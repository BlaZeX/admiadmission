---
const { eyebrow, title, description, align = 'center' } = Astro.props;
const alignment = align === 'left' ? 'text-left items-start' : 'text-center items-center mx-auto';
---
<div class={`mb-10 flex max-w-3xl flex-col ${alignment}`}>
  {eyebrow && <p class="mb-3 rounded-full border border-blue-100 bg-mist px-4 py-2 text-xs font-extrabold uppercase tracking-[0.2em] text-brand">{eyebrow}</p>}
  <h2 class="font-display text-3xl font-bold tracking-tight text-navy sm:text-4xl">{title}</h2>
  {description && <p class="mt-4 text-base leading-7 text-slate-600 sm:text-lg">{description}</p>}
</div>
