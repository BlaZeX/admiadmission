---
const videos = [
  ['Step 1: Register on Samarth Admission Portal', 'trgjW7fEjM8'],
  ['Step 2: Programme Selection / Apply for Programme', 'KzmxhxF5C0Y'],
  ['Step 3: Final Submission', 'YPEq9w4TcTA'],
];
---
<div class="grid gap-6 lg:grid-cols-3">
  {videos.map(([title, id]) => (
    <article class="rounded-3xl border border-slate-100 bg-white p-4 shadow-card">
      <div class="video-frame">
        <iframe loading="lazy" src={`https://www.youtube-nocookie.com/embed/${id}`} title={title} allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
      </div>
      <h3 class="mt-5 px-2 pb-2 text-base font-extrabold text-navy">{title}</h3>
    </article>
  ))}
</div>
