---
const samarth = 'https://muugadmission.samarth.edu.in/';
const steps = [
  ['Visit Mumbai University Samarth Admission Portal', 'Open the official admission portal and start from the correct website.', samarth],
  ['Complete new registration on the portal', 'Create your student registration with accurate personal and contact details.'],
  ['Login and apply for a programme', 'After registration, login and choose the option to apply for a programme.'],
  ['Select the correct programme and institute', 'Choose B.Com (Retail Operations Management) (AEDP) and Alkesh Dinesh Mody Institute for Financial & Management Studies.'],
  ['Upload documents and complete final online submission', 'Upload required documents carefully and submit the online application.'],
  ['Visit the institute for offline confirmation', 'Come to the institute for offline admission confirmation and document verification.'],
];
---
<div class="grid gap-5 lg:grid-cols-2">
  {steps.map(([title, text, link], index) => (
    <article class="relative rounded-3xl border border-slate-100 bg-white p-6 shadow-card">
      <div class="mb-4 flex items-center gap-4">
        <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-navy text-lg font-black text-white">{index + 1}</span>
        <h3 class="text-lg font-extrabold text-navy">{title}</h3>
      </div>
      <p class="text-sm leading-6 text-slate-600">{text}</p>
      {link && <a class="mt-4 inline-flex text-sm font-extrabold text-purple underline-offset-4 hover:underline" href={link} target="_blank" rel="noopener noreferrer">{link}</a>}
    </article>
  ))}
</div>
<div class="mt-8 rounded-3xl border border-red-200 bg-red-50 p-6 text-red-950 shadow-sm">
  <p class="font-extrabold">Without online admission on the Samarth portal, offline admission at the institute cannot be completed.</p>
</div>
