---
const semesters = [
  ['Semester I', ['Business Organizations and Management', 'Business Communication and Basic Office IT Application', 'Introduction to Retail Operations', 'In-store Cashiering and Merchandising Operations']],
  ['Semester II', ['Principles of Marketing', 'Social Media Marketing and Advertising', 'Customer Relationship Management', 'FMCG / FMCD Sales and Distribution']],
  ['Semester III', ['Retail Sales Management', 'Financial and Cost Accounting', 'Managerial Economics', 'E-commerce and Omnichannel Retailing']],
  ['Semester IV', ['Logistics and Supply Chain Management', 'Inventory and Budget Management', 'Retail Entrepreneurship', 'Retail Team Management', 'Visual Merchandising', 'OJT: Hands-on ERP']],
  ['Semester V', ['Strategic Marketing Research', 'Legal Framework for Retail Business Enterprises', 'Apprenticeship']],
  ['Semester VI', ['Sustainable Work Practices in Retail Operations', 'Sales and Negotiation Techniques', 'SWAYAM Course', 'Apprenticeship']],
];
---
<div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
  {semesters.map(([semester, subjects]) => (
    <details class="group rounded-3xl border border-slate-100 bg-white p-6 shadow-card" open={semester === 'Semester I'}>
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-lg font-extrabold text-navy">
        {semester}
        <span class="rounded-full bg-lavender px-3 py-1 text-sm text-purple transition group-open:rotate-45">+</span>
      </summary>
      <ul class="mt-5 space-y-3 text-sm leading-6 text-slate-600">
        {subjects.map((subject) => <li class="flex gap-3"><span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-purple"></span><span>{subject}</span></li>)}
      </ul>
    </details>
  ))}
</div>
