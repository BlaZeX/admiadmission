---
const { icon = '✨', title, description } = Astro.props;
---
<article class="card-hover rounded-3xl border border-slate-100 bg-white p-6 shadow-card">
  <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-lavender to-skysoft text-2xl" aria-hidden="true">{icon}</div>
  <h3 class="text-lg font-extrabold text-navy">{title}</h3>
  {description && <p class="mt-3 text-sm leading-6 text-slate-600">{description}</p>}
</article>
